LOG_LEVEL=INFO

COMMAND_PREFIX=!
ACTIVITY_ROTATION_ENABLED=true
ACTIVITY_ROTATION_INTERVAL_SECONDS=60
ACTIVITY_ALLOWED_ORIGINS=
